# ============================================
# LINKEDIN SCRAPER V2 — Variables de entorno
# Copia este archivo a .env.local y rellena los valores
# NUNCA subas .env.local a git
#
# Última revisión: 2026-06-04 (auditoría de infraestructura)
# ============================================

# ── SUPABASE ──────────────────────────────────────────
# Obtener en: supabase.com → tu proyecto → Settings → API

# URL del proyecto (pública, puede exponerse al frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co

# Anon key — necesaria en DOS formatos (browser client + server fallback)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ↑ mismo valor que NEXT_PUBLIC_SUPABASE_ANON_KEY — necesario para la ruta /api/auth/signin

# Service Role Key — NUNCA exponer al frontend; solo server-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── ANTHROPIC — Agente de Redacción ───────────────────
# Modelo usado: claude-sonnet-4-6 (scripts/orchestrate.ts)
# Obtener en: console.anthropic.com → API Keys → Create Key
# 🔴 CRÍTICO: sin esta key el orquestador no arranca
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OPENAI — Scraper (parsing de snippets) ────────────
# Modelo usado: gpt-4o-mini (src/lib/claude_prompts.ts)
# Obtener en: platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...

# ── MOTOR DE BÚSQUEDA — SearchAPI.io ─────────────────
# NOTA: El proyecto usa SearchAPI.io (proxy de Google), NO Google CSE directamente.
# Las variables GOOGLE_API_KEY y GOOGLE_CX son obsoletas (V1) y no se usan.
# Obtener en: searchapi.io → Dashboard → API Key
SEARCHAPI_IO_KEY=...

# ── SEGURIDAD INTERNA ─────────────────────────────────
# Clave que protege los endpoints /api/* del scraper (header x-api-key)
# Genera una aleatoria en bash: openssl rand -hex 32

# Server-side guard (leída por las API routes en /src/app/api/)
SEARCH_API_KEY=change_this_to_a_random_secret_key

# Client-side — expuesta al frontend para incluirla en el header x-api-key
# DEBE coincidir exactamente con SEARCH_API_KEY
NEXT_PUBLIC_SEARCH_API_KEY=change_this_to_a_random_secret_key

# ── APP ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email del administrador inicial (configuración del dashboard)
NEXT_PUBLIC_ADMIN_EMAIL=admin@tudominio.com
